generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MANDOR
  HEAD_WORKER
}

enum FileType {
  PHOTO
  VIDEO
}

enum DocumentationSession {
  PAGI
  SORE
}

enum ProjectStatus {
  AKTIF
  LIBUR
  SELESAI
}

model User {
  id       String   @id @default(uuid())
  name     String
  username String   @unique
  email    String   @unique
  password String
  role     UserRole

  projects         Project[] @relation("MandorProjects")
  assignedProjects Project[] @relation("ProjectHeadWorkers")

  // relasi mandor → head worker
  mandorId    String?
  mandor      User?   @relation("MandorHeadWorkers", fields: [mandorId], references: [id])
  headWorkers User[]  @relation("MandorHeadWorkers")

  documentationsCreated Documentation[] @relation("DocumentationCreatedBy")
  documentationsUpdated Documentation[] @relation("DocumentationUpdatedBy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
  @@index([mandorId])
  @@index([role])
}

model Project {
  id          String    @id @default(uuid())
  projectName String
  location    String
  startDate   DateTime
  endDate     DateTime?
  description String?

  status ProjectStatus @default(AKTIF)

  documentations Documentation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mandorId    String
  mandor      User   @relation("MandorProjects", fields: [mandorId], references: [id], onDelete: Restrict)
  headWorkers User[] @relation("ProjectHeadWorkers")

  @@index([deletedAt])
  @@index([mandorId, deletedAt])
  @@index([mandorId, status])
  @@index([mandorId, createdAt])
  @@index([status, deletedAt])
  @@index([createdAt])
}

model Documentation {
  id String @id @default(uuid())

  reportDate DateTime
  uploadedAt DateTime             @default(now())
  session    DocumentationSession

  workArea String
  task     String

  target   String?
  progress String?

  createdById String
  updatedById String?

  createdBy User  @relation("DocumentationCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("DocumentationUpdatedBy", fields: [updatedById], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  files DocumentationFile[]

  @@index([projectId, reportDate(sort: Desc)])
  @@index([projectId, session, reportDate])
  @@index([createdById])
}

model DocumentationFile {
  id String @id @default(uuid())

  fileUrl      String
  cloudinaryId String
  fileType     FileType

  documentationId String
  documentation   Documentation @relation(fields: [documentationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([documentationId])
}
